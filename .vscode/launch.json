{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Fixed VSCode)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      // "preLaunchTask": "pnpm: watch",
      // "postDebugTask": "kill pnpm: watch"
    },
    {
      "name": "Run Extension (Compile Once)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "pnpm: compile"
    }
  ]
}