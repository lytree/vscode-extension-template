{
  "name": "vscode-extension-template",
  "displayName": "VSCode Extension Template",
  "description": "TypeScript VS Code extension template (Node.js 22 + pnpm) with WebviewPanel and WebviewViewProvider.",
  "version": "0.6.1",
  "publisher": "your-publisher",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "vscode": "^1.115.0",
    "node": ">=22.0.0"
  },
  "type": "module",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vscode-extension-template.helloWorld",
    "onCommand:vscode-extension-template.openPanel",
    "onView:template.webviewView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fenbi.refreshEntry",
        "title": "刷新",
        "icon": "$(extensions-refresh)"
      },
      {
        "command": "fenbi.navigateToTiku",
        "title": "题库",
        "icon": "$(library)"
      },
      {
        "command": "fenbi.navigateToHistory",
        "title": "练习历史",
        "icon": "$(history)"
      },
      {
        "command": "fenbi.navigateToPastYears",
        "title": "历年题库",
        "icon": "$(file-text)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "viewBar",
          "title": "粉笔",
          "icon": "resources/template.svg"
        }
      ]
    },
    "views": {
      "viewBar": [
        {
          "type": "webview",
          "id": "fenbi.webviewView",
          "name": ""
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "fenbi.refreshEntry",
          "when": "view == fenbi.webviewView",
          "group": "navigation@1"
        },
        {
          "command": "fenbi.navigateToTiku",
          "when": "view == fenbi.webviewView",
          "group": "navigation@2"
        },
        {
          "command": "fenbi.navigateToHistory",
          "when": "view == fenbi.webviewView",
          "group": "navigation@3"
        },
        {
          "command": "fenbi.navigateToPastYears",
          "when": "view == fenbi.webviewView",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "FenbiTools",
      "properties": {
        "fenbiTools.cookie": {
          "type": "string",
          "default": "",
          "markdownDescription": "cookie，必填，请修改后刷新",
          "editPresentation": "multilineText"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true }); require('node:fs').rmSync('media', { recursive: true, force: true });\"",
    "compile": "pnpm run clean && pnpm run compile:ext && pnpm run compile:web",
    "build": "pnpm run compile",
    "compile:ext": "tsc -p tsconfig.ext.json",
    "compile:web": "vite build --config vite.config.ts",
    "watch": "concurrently \"pnpm run watch:ext\" \"pnpm run watch:web\"",
    "dev": "pnpm run watch",
    "watch:ext": "tsc -watch -p tsconfig.ext.json",
    "watch:web": "vite build --watch --config vite.config.ts",
    "lint": "eslint \"extension/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.ext.json",
    "check": "pnpm run lint && pnpm run typecheck",
    "pretest": "pnpm run compile && pnpm run lint",
    "test": "node ./out/test/runTest.js",
    "package": "pnpm run package:vsix",
    "package:vsix": "pnpm run compile && pnpm dlx @vscode/vsce package --no-dependencies",
    "package:vsix:dev": "pnpm run compile && pnpm dlx @vscode/vsce package --pre-release --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "dayjs": "^1.11.20",
    "lucide-react": "^1.12.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "shadcn": "^4.6.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  }
}
