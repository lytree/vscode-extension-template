{
  "name": "vscode-extension-template",
  "displayName": "VSCode Extension Template",
  "description": "TypeScript VS Code extension template (Node.js 22 + pnpm) with WebviewPanel and WebviewViewProvider.",
  "version": "0.6.1",
  "publisher": "your-publisher",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=22.0.0"
  },
  "type": "module",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vscode-extension-template.helloWorld",
    "onCommand:vscode-extension-template.openPanel",
    "onView:template.webviewView",
    "onView:openViewWebview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-extension-template.helloWorld",
        "title": "Template: Hello World"
      },
      {
        "command": "vscode-extension-template.openPanel",
        "title": "Template: Open Webview Panel"
      },
      {
        "command": "openViewWebview.refreshEntry",
        "title": "刷新",
        "icon": {
          "light": "resources/light/refresh.svg",
          "dark": "resources/dark/refresh.svg"
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "template-sidebar",
          "title": "Template",
          "icon": "resources/template.svg"
        },
        {
          "id": "viewBar",
          "title": "view",
          "icon": "resources/fenbi.svg"
        }
      ]
    },
    "views": {
      "template-sidebar": [
        {
          "id": "template.webviewView",
          "type": "webview",
          "name": "Template View"
        }
      ],
      "viewBar": [
        {
          "type": "webview",
          "id": "openViewWebview",
          "name": "container"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "openViewWebview.refreshEntry",
          "group": "navigation",
          "when": "view == openViewWebview"
        }
      ]
    },
    "configuration": {
      "title": "FenbiTools",
      "properties": {
        "fenbiTools.cookie": {
          "type": "string",
          "default": "",
          "markdownDescription": "cookie，必填，请修改后刷新",
          "editPresentation": "multilineText"
        },
        "fenbiTools.color": {
          "type": "string",
          "default": "#ffffff",
          "markdownDescription": "自定义字体color颜色，请填写色值，非中文！请修改后刷新"
        },
        "fenbiTools.backgroundColor": {
          "type": "string",
          "default": "#21222b",
          "markdownDescription": "自定义背景bgColor颜色，请填写色值，非中文！请修改后刷新"
        },
        "fenbiTools.needLineThrough": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "开启后，选项后会增加排除按钮，点击即可给当前选项增加中划线"
        },
        "fenbiTools.fontSize": {
          "type": "number",
          "default": 12,
          "markdownDescription": "自定义字体大小（单位px），默认12，请修改后刷新"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true }); require('node:fs').rmSync('media', { recursive: true, force: true });\"",
    "compile": "pnpm run clean && pnpm run compile:ext && pnpm run compile:web",
    "build": "pnpm run compile",
    "compile:ext": "tsc -p ./",
    "compile:web": "vite build --config vite.config.ts",
    "watch": "concurrently \"pnpm run watch:ext\" \"pnpm run watch:web\"",
    "dev": "pnpm run watch",
    "watch:ext": "tsc -watch -p ./",
    "watch:web": "vite build --watch --config vite.config.ts",
    "lint": "eslint \"extension/**/*.ts\"",
    "typecheck": "tsc --noEmit -p ./",
    "check": "pnpm run lint && pnpm run typecheck",
    "pretest": "pnpm run compile && pnpm run lint",
    "test": "node ./out/test/runTest.js",
    "package": "pnpm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.115.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "dayjs": "^1.11.20",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.9.4",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  }
}